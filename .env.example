# RPC endpoints
ORIGIN_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
DESTINATION_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
REACTIVE_RPC_URL=https://lasna-rpc.rnk.dev/

# Private keys
ORIGIN_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
DESTINATION_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
REACTIVE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Chain IDs
ORIGIN_CHAIN_ID=11155111
DESTINATION_CHAIN_ID=11155111

# Reactive callback proxy for the destination chain
DESTINATION_CALLBACK_PROXY_ADDR=0xc9f36411C9897e7F959D99ffca2a0Ba7ee0D7bDA

# Computed from your local event signature:
# cast keccak "Received(address,address,uint256)"
TOPIC0=

# Filled after deployment
ORIGIN_CONTRACT_ADDR=
CALLBACK_ADDR=

# Scratch source deployment
SCRATCH_TICKET_PRICE=10000000000000000
SCRATCH_INITIAL_ROUND_ID=1
TICKET_PURCHASED_TOPIC0=
SCRATCH_SOURCE_ADDR=

# Scratch game deployment
# Chainlink VRF v2.5 Sepolia values are listed on:
# https://docs.chain.link/vrf/v2-5/supported-networks
# Example as of 2026-03-23:
# VRF_COORDINATOR_ADDR=0x9DdfaCa8183c41ad55329BdeeD9F6A8d53168B1B
# VRF_KEY_HASH=0x787d74caea10b2b357790d5b5247c2f63d1d91572a9846f780606e4d953677ae
VRF_COORDINATOR_ADDR=
VRF_KEY_HASH=
VRF_SUBSCRIPTION_ID=
VRF_REQUEST_CONFIRMATIONS=3
VRF_CALLBACK_GAS_LIMIT=200000
VRF_NATIVE_PAYMENT=true
SCRATCH_GAME_INITIAL_FUNDING=200000000000000000
SCRATCH_GAME_ADDR=
MOCK_FULFILL_TICKET_ID=
MOCK_RANDOM_WORD=50
DEMO_MODE_ENABLED=false
DEMO_FORCED_PRIZE_TIER=3
DEMO_REMAINING_TICKETS=1

# Scratch reactive deployment
SCRATCH_REACTIVE_INITIAL_FUNDING=100000000000000000
SCRATCH_REACTIVE_ADDR=
EXPECTED_REACTIVE_SENDER_ADDR=
